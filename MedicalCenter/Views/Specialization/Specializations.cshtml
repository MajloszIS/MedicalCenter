@model List<MedicalCenter.DTOs.SpecializationDto>

@{
    ViewData["Title"] = "Specjalizacje";
}

<div class="row g-4">
    <div class="col-lg-6">
        <h4 class="page-title">Dodaj nową specjalizację</h4>
        <form asp-action="CreateSpecialization" asp-controller="Specialization" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">Nazwa specjalizacji</label>
                <input type="text" id="Name" name="Name"
                       class="form-control" required placeholder="Wprowadź nazwę specjalizacji" />
            </div>

            <div>
                @if (ViewBag.Error != null)
                {
                    <span>@ViewBag.Error</span>
                }
            </div>
            <button type="submit" class="btn btn-medical w-100 fw-bold mt-3">
                <i class="fa-regular fa-plus me-2"></i>Dodaj
            </button>
        </form>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
                <h2 class="page-title mb-3"><i class="fa-solid fa-stethoscope me-2"></i>Specjalizacje</h2>
            @if (!Model.Any())
            {
                <div class="medical-card text-center py-5">
                    <i class="fa-solid fa-calendar-xmark text-muted mb-3" style="font-size: 3rem;"></i>
                    <h4>Brak specjalizacji</h4>
                    <p class="text-muted">Nie masz jeszcze żadnych zarejestrowanych specjalizacji.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-custom align-middle">
                        <thead>
                            <tr>
                                <th class="text-center">Nazwa</th>
                                <th class="text-center">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-center">@item.Name</div>
                                    </td>
                                    <td class="text-center justify-content-around d-flex"> 
                                        <div class="fw-bold">
                                            <form asp-action="EditSpecialization" asp-controller="Specialization" method="post">
                                                @Html.AntiForgeryToken()

										    	<input type="hidden" name="specializationId" value="@item.Id" />
                                                <div class="d-flex align-items-center mb-3">

                                                    <span id="name-text"></span>

                                                    <input id="name-input" name="Name" value="@item.Name"
                                                           class="form-control form-control-sm ms-2" style="display:none; width:200px;" />

                                                    <button type="button" id="name-edit" onclick="enableEdit('name')"
                                                            class="btn btn-sm btn-link ms-2">

                                                        <i class="fa-solid fa-pen text-primary"></i>
                                                    </button>
                                                    <button type="submit" id="name-save" class="btn btn-sm btn-success ms-2"
                                                            style="display:none;">
                                                        <i class="fa-solid fa-check"></i>
                                                    </button>

                                                </div>
                                            </form>
                                        </div>
                                        <div class="fw-bold">
                                            <form asp-action="DeleteSpecialization" asp-controller="Specialization" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="specializationId" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {

    <script>
        function enableEdit(fieldId) {
            const span = document.getElementById(`${fieldId}-text`);
            const input = document.getElementById(`${fieldId}-input`);
            const editBtn = document.getElementById(`${fieldId}-edit`);
            const saveBtn = document.getElementById(`${fieldId}-save`);

            span.style.display = 'none';
            input.style.display = 'inline';
            editBtn.style.display = 'none';
            saveBtn.style.display = 'inline';
        }

        document.getElementById('profilePicture').addEventListener('change', function() {
            const fileName = this.files[0]?.name ?? 'Nie wybrano pliku';
            document.getElementById('fileName').textContent = fileName;
        });
    </script>
}

