@model MedicalCenter.Models.Cart

<div class="container mt-4">
    <h2>Twój Koszyk</h2>

    @if (Model == null || !Model.Items.Any())
    {
        <div class="alert alert-info">Twój koszyk jest pusty.</div>
        <a asp-controller="Medicines" asp-action="Index" class="btn btn-primary">Wróć do apteki</a>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Lek</th>
                    <th>Cena</th>
                    <th>Ilość</th>
                    <th>Suma</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Medicine.Name</td>
                        <td>@item.Medicine.Price.ToString("C")</td>
                        <td>@item.Quantity</td>
                        <td>@((item.Quantity * item.Medicine.Price).ToString("C"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="text-end">
            <h4>Suma całkowita: @Model.Items.Sum(i => i.Quantity * i.Medicine.Price).ToString("C")</h4>
            <form asp-action="Checkout" method="post">
                <button type="submit" class="btn btn-success btn-lg">Złóż zamówienie</button>
            </form>
        </div>
    }
</div>