@model MedicalCenter.Models.Cart

@{
    ViewData["Title"] = "Twój Koszyk";
}

<div class="container mt-4">
    <h2>Twój Koszyk</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Items.Any())
    {
        <div class="alert alert-info">Twój koszyk jest pusty.</div>
        <a asp-controller="Medicines" asp-action="Index" class="btn btn-primary">Wróć do apteki</a>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Lek</th>
                        <th>Cena</th>
                        <th>Ilość</th>
                        <th>Suma</th>
                        <th class="text-center">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-bold">@item.Medicine.Name</td>
                            <td>@item.Medicine.Price.ToString("C")</td>
                            <td>@item.Quantity</td>
                            <td>@((item.Quantity * item.Medicine.Price).ToString("C"))</td>
                            <td class="text-center">
                                <form asp-controller="Cart" asp-action="RemoveItem" method="post">
                                    <input type="hidden" name="medicineId" value="@item.MedicineId" />
                                    <button type="submit" class="btn btn-danger">
                                        Usuń
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-end mt-4">
            <h4>Suma całkowita: <span class="text-success fw-bold">@Model.Items.Sum(i => i.Quantity * i.Medicine.Price).ToString("C")</span></h4>
            <div class="mt-3">
                <a asp-controller="Medicines" asp-action="Index" class="btn btn-outline-secondary">Kontynuuj zakupy</a>
                <form asp-action="Checkout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-success btn-lg">Złóż zamówienie</button>
                </form>
            </div>
        </div>
    }
</div>