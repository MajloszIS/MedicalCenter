@model List<MedicalCenter.Models.MedicineCategory>

@{
    ViewData["Title"] = "Kategorie leków";
}

<div class="row g-4">
    <div class="col-lg-6">
        <h4 class="page-title border-bottom pb-2 mb-4">Dodaj nową kategorię</h4>
        <form asp-action="AddMedicineCategory" asp-controller="MedicineCategories" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">Nazwa kategorii</label>
                <input type="text" id="Name" name="Name"
                       class="form-control" required placeholder="np. Suplementy" />
            </div>

            <div>
                @if (TempData["Error"] != null)
                {
                    <span class="text-danger small fw-bold">@TempData["Error"]</span>
                }
                @if (TempData["SuccessMessage"] != null)
                {
                    <span class="text-success small fw-bold">@TempData["SuccessMessage"]</span>
                }
            </div>

            <button type="submit" class="btn btn-medical w-100 fw-bold mt-3">
                <i class="fa-solid fa-plus me-2"></i>Dodaj
            </button>
        </form>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-8">
            <h2 class="page-title mb-3"><i class="fa-solid fa-pills me-2"></i>Kategorie leków</h2>

            @if (!Model.Any())
            {
                <div class="medical-card text-center py-5">
                    <i class="fa-solid fa-folder-open text-muted mb-3" style="font-size: 3rem;"></i>
                    <h4>Brak kategorii</h4>
                    <p class="text-muted">Nie masz jeszcze żadnych zarejestrowanych kategorii leków.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-custom align-middle">
                        <thead>
                            <tr>
                                <th class="text-center w-50">Nazwa</th>
                                <th class="text-center w-50">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <div id="@item.Id-text" class="fw-bold">@item.Name</div>

                                        <form asp-action="EditMedicineCategory" asp-controller="MedicineCategories" method="post" id="form-@item.Id" class="m-0" style="display:none;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input name="Name" value="@item.Name" class="form-control form-control-sm mx-auto" style="max-width: 200px;" required />
                                        </form>
                                    </td>

                                    <td class="text-center justify-content-around d-flex align-items-center py-3">

                                        <div class="fw-bold">
                                            <button type="button" id="@item.Id-edit" onclick="enableEdit('@item.Id')" class="btn btn-sm btn-link text-decoration-none p-0">
                                                <i class="fa-solid fa-pen text-primary"></i>
                                            </button>

                                            <button type="submit" id="@item.Id-save" form="form-@item.Id" class="btn btn-sm btn-success" style="display:none;">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                        </div>

                                        <div class="fw-bold">
                                            <form asp-action="DeleteMedicineCategory" asp-controller="MedicineCategories" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Czy na pewno chcesz usunąć tę kategorię?');">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </button>
                                            </form>
                                        </div>

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function enableEdit(fieldId) {
            document.getElementById(`${fieldId}-text`).style.display = 'none';
            document.getElementById(`form-${fieldId}`).style.display = 'block';

            document.getElementById(`${fieldId}-edit`).style.display = 'none';
            document.getElementById(`${fieldId}-save`).style.display = 'inline-block';
        }
    </script>
}