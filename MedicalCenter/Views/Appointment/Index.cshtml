@model List<MedicalCenter.DTOs.AppointmentDto>

@{
    ViewData["Title"] = "Moje Wizyty";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-calendar-check me-2"></i>Twoje Wizyty</h2>
    <a asp-controller="Doctors" asp-action="Index" class="btn btn-outline-primary fw-bold">
        <i class="fa-solid fa-plus me-2"></i>Nowa Wizyta
    </a>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-calendar-xmark text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak zaplanowanych wizyt</h4>
        <p class="text-muted">Nie masz jeszcze żadnych umówionych wizyt w naszym centrum.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Lekarz</th>
                    <th>Specjalizacja</th>
                    <th>Data i Godzina</th>
                    <th>Status</th>
                    <th class="text-center">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Doctor.FirstName @item.Doctor.LastName</div>
                        </td>
                        <td><span class="badge bg-light text-dark">@item.Doctor.SpecializationName</span></td>
                        <td>
                            <div class="text-primary fw-semibold">
                                <i class="fa-regular fa-clock me-1"></i> @item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </td>
                        <td>
                            @{
                                var statusClass = item.StatusName == "Zakończona" ? "bg-success" :
                                item.StatusName == "Odwołana" ? "bg-danger" : "bg-warning text-dark";
                            }
                            <span class="badge @statusClass">@item.StatusName</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-controller="Appointment"
                               asp-route-AppointmentId="@item.Id" class="btn btn-medical w-100 fw-bold">
                                <i class="fa-solid fa-circle-info me-2"></i> Szczegóły
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}