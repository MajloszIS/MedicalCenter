@{
    ViewData["Title"] = "Umów Wizytę";
}

<h2>Umów Wizytę </h2>

<form asp-action="Create" asp-controller="Appointment" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="DoctorId" value="@ViewBag.DoctorId" />

    <div>
        <label>Data</label>
        <input type="datetime-local" name="appointmentDate" required />
    </div>

    <div>
        <label>Opis</label>
        <textarea name="Description" required></textarea>
    </div>

    <div>
        @if (ViewBag.Error != null)
        {
            <span>@ViewBag.Error</span>
        }
    </div>
    <button type="submit">Potwierdz</button>
</form>

<a href="/Home">Powrót</a>