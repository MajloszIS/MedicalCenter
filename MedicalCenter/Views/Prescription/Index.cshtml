@model List<MedicalCenter.DTOs.PrescriptionDto>

@{
	ViewData["Title"] = "Twoje Recepty";
}


<div class="d-flex justify-content-between align-items-center mb-5">
	<h2 class="page-title mb-0"><i class="fa-solid fa-calendar-check me-2"></i>Twoje Recepty</h2>
</div>

@foreach(var prescription in Model)
{
    <div class="medical-card row g-4 mb-5">

        <div class="col-lg-4">
            
			<div class="row g-4">
				<div class="row g-2">
					<h5>
						
						@if (/*Model.ProfilePicturePath != null*/ false)
						{
							//<img src="@Model.ProfilePicturePath" alt="Zdjęcie profilowe"
							//style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover;" />
						}
						else
						{
							<i class="fa-solid fa-user-md"></i>
						}
						@prescription.Doctor.FirstName @prescription.Doctor.LastName
							
					</h5>
				</div>

				<div class="row g-2">

					<div class="col-6">
						<div class="d-flex align-items-center mb-1">
							<i class="fa-solid fa-phone me-2 text-primary"></i>
							<p class="text-muted small mb-0">Telefon</p>
						</div>
						<p class="fw-semibold">@prescription.Doctor.Phone</p>
					</div>

					<div class="col-6">
						<div class="d-flex align-items-center mb-1">
							<i class="fa-solid fa-id-card me-2 text-primary"></i>
							<p class="text-muted small mb-0">Specjalizacja</p>
						</div>
						<p class="fw-semibold">@prescription.Doctor.SpecializationName</p>
					
					</div>
				
					<a asp-action="DownloadPdf" asp-route-id="@prescription.Id" class="btn btn-primary">
						Pobierz PDF
					</a>

				</div>
			</div>

        </div>
        
        <div class="col-lg-8">
            @foreach(var item in prescription.Items)
            {
				<div class="d-flex align-items-center justify-content-between border rounded p-2 mb-2">

					<div>
						<i class="fa-solid fa-pills text-primary me-2"></i>
						<span class="fw-semibold">@item.Medicine.Name</span>
						<span class="text-muted ms-2">— @item.Quantity szt.</span>
					</div>

					<input type="hidden" name="medicineIds" value="@item.MedicineId" />
					<input type="hidden" name="quantities" value="@item.Quantity" />
				</div>
            }


        </div>

    </div>
}
