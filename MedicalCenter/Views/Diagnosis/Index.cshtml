@model List<MedicalCenter.DTOs.DiagnosisDto>

@{
	ViewData["Title"] = "Twoje Diagnozy";
}


<div class="d-flex justify-content-between align-items-center mb-5">
	<h2 class="page-title mb-0"><i class="fa-solid fa-calendar-check me-2"></i>Diagnozy</h2>
</div>

@foreach (var diagnosis in Model)
{
    <div class="medical-card row g-4 mb-5">
        <div class="col-lg-8">
			<div class="d-flex justify-content-between align-items-center mb-1">
				<h6 class="page-title mb-0"><i class="fa-solid fa-calendar-check me-2"></i>Diagnoza z dnia @diagnosis.DiagnosedAt.ToString("dd.MM.yyyy")</h6>
			</div>
			<p>@diagnosis.Description</p>

			<h6 class="text-muted mt-3">
				<i class="fa-solid fa-book-medical me-1"></i>Leczenie
			</h6>
			@foreach (var treatment in diagnosis.Treatments)
			{
				<p>@treatment.Description</p>
			}


        </div>

    </div>
}
