@model List<MedicalCenter.DTOs.MedicineDto>

@{
    ViewData["Title"] = "Leki";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-pills me-2"></i>Asortyment leków</h2>
    <a asp-controller="Admin" asp-action="CreateMedicine" class="btn btn-outline-primary fw-bold">
        <i class="fa-solid fa-plus me-2"></i>Dodaj lek
    </a>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-pills text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak leków w bazie</h4>
        <p class="text-muted">Nie masz jeszcze żadnych zarejestrowanych leków w aptece.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Nazwa leku</th>
                    <th>Kategoria</th>
                    <th>Cena jednostkowa</th>
                    <th class="text-center">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Name</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.CategoryName</div>
                        </td>
                        <td>
                            <div class="fw-bold text-success">@item.Price.ToString("C")</div>
                        </td>
                        <td class="text-center justify-content-center d-flex gap-3">
                            <div class="fw-bold">
                                <a asp-action="EditMedicine" asp-controller="Admin" asp-route-medicineId="@item.Id" class="fw-bold text-primary">
                                    <i class="fa-solid fa-pen me-1"></i>
                                </a>
                            </div>

                            <div class="fw-bold">
                                <form asp-action="DeleteMedicine" asp-controller="Admin" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="medicineId" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('Na pewno usunąć ten lek?');">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}