@model List<MedicalCenter.DTOs.SpecializationMonthlyReportDto>

@{
    ViewData["Title"] = "Raport specjalizacji";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">
        <i class="fa-solid fa-stethoscope me-2"></i>Raport miesięczny specjalizacji
    </h2>
    <a asp-action="Analytics" asp-controller="Admin" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Wróć
    </a>
</div>

<div class="medical-card p-4 mb-4">
    <form method="get" asp-action="MonthlySpecializationReport" asp-controller="Admin">
        <div class="row align-items-end">
            <div class="col-md-4">
                <label class="form-label">Rok</label>
                <input type="number" name="year" value="@ViewBag.Year" class="form-control" min="2000" max="2100" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Miesiąc</label>
                <input type="number" name="month" value="@ViewBag.Month" class="form-control" min="1" max="12" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fa-solid fa-search me-1"></i>Generuj raport
                </button>
            </div>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-stethoscope text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak danych</h4>
        <p class="text-muted">Brak danych dla wybranego okresu.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Specjalizacja</th>
                    <th class="text-center">Aktywni lekarze</th>
                    <th class="text-center">Unikalni pacjenci</th>
                    <th class="text-center">Zaplanowane</th>
                    <th class="text-center">Zakończone</th>
                    <th class="text-center">Anulowane</th>
                    <th class="text-center">Recepty</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.SpecializationName</td>
                        <td class="text-center">@item.ActiveDoctorsCount</td>
                        <td class="text-center">@item.UniquePatientsCount</td>
                        <td class="text-center">
                            <span class="badge bg-warning text-dark">@item.ScheduledCount</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-success">@item.CompletedCount</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-danger">@item.CancelledCount</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info">@item.PrescriptionsIssued</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}