@{
    ViewData["Title"] = "Analityka";
}

<h2 class="page-title mb-4">
    <i class="fa-solid fa-chart-bar me-2"></i>Analityka
</h2>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="medical-card p-4">
            <h5><i class="fa-solid fa-users me-2"></i>Demografia pacjentów</h5>
            <p class="text-muted">Analiza pacjentów według wieku, płci i miasta.</p>
            <a asp-action="PatientDemographics" asp-controller="Admin" class="btn btn-primary">
                Przejdź do raportu
            </a>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="medical-card p-4">
            <h5><i class="fa-solid fa-stethoscope me-2"></i>Raport specjalizacji</h5>
            <p class="text-muted">Miesięczny raport wizyt per specjalizacja.</p>
            <a asp-action="MonthlySpecializationReport" asp-controller="Admin" class="btn btn-primary">
                Przejdź do raportu
            </a>
        </div>
    </div>
</div>