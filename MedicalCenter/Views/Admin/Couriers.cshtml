@model List<MedicalCenter.DTOs.CourierDto>

@{
    ViewData["Title"] = "Kurierzy";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-truck me-2"></i>Kurierzy</h2>
    <a asp-controller="Admin" asp-action="CreateCourier" class="btn btn-outline-primary fw-bold">
        <i class="fa-solid fa-plus me-2"></i>Dodaj Kuriera
    </a>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-calendar-xmark text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak kurierów</h4>
        <p class="text-muted">Nie masz jeszcze żadnych zarejestrowanych kurierów.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Imię</th>
                    <th>Nazwisko</th>
                    <th>Telefon</th>
                    <th>Auto (Rejestracja)</th>
                    <th class="text-center">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.FirstName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.LastName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.Phone</div>
                        </td>
                        <td>
                            <div class="fw-bold text-secondary">@(string.IsNullOrEmpty(item.VehicleRegistration) ? "Brak" : item.VehicleRegistration)</div>
                        </td>


                        <td class="text-center justify-content-center d-flex gap-2">

                            <div class="fw-bold">
                                <a asp-action="CourierDeliveries" asp-controller="Admin" asp-route-courierId="@item.Id" class="btn btn-sm btn-outline-info" title="Paczki kuriera">
                                    <i class="fa-solid fa-box"></i>
                                </a>
                            </div>

                            <div class="fw-bold">
                                <a asp-action="EditCourier" asp-controller="Admin" asp-route-courierId="@item.Id" class="btn btn-sm btn-outline-primary" title="Edytuj kuriera">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                            </div>

                            <div class="fw-bold">
                                <form asp-action="DeleteCourier" asp-controller="Admin" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="courierId" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Usuń kuriera">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </form>
                            </div>

                        </td>
                       

                    </tr>
                }
            </tbody>
        </table>
    </div>
}