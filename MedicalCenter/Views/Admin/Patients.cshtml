@model List<MedicalCenter.DTOs.PatientDto>

@{
    ViewData["Title"] = "Pacjenci";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-list me-2"></i>Pacjenci w Centrum Medycznym</h2>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-calendar-xmark text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak pacjentów</h4>
        <p class="text-muted">Nie masz jeszcze żadnych zarejestrowanych pacjentów.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Imię</th>
                    <th>Nazwisko</th>
                    <th>Telefon</th>
                    <th>PESEL</th>
                    <th class="text-center">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.FirstName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.LastName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.Phone</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.Pesel</div>
                        </td>
                        <td class="text-center justify-content-between d-flex">
                            <div class="fw-bold">
                                <a asp-action="PatientAppointments" asp-controller="Admin"
                                       asp-route-patientId="@item.Id" class="fw-bold">
                                    <i class="fa-solid fa-file-medical me-1"></i>
                                </a>
                            </div>
                            <div class="fw-bold">
                                <a asp-action="EditPatient" asp-controller="Admin"
                                       asp-route-patientId="@item.Id" class="fw-bold">
                                    <i class="fa-solid fa-pen me-1"></i>
                                </a>
                            </div>
                            <div class="fw-bold">
                                <form asp-action="DeletePatient" asp-controller="Admin" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="patientId" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-center mt-3">
            @{
                int current = ViewBag.CurrentPage;
                int total = ViewBag.TotalPages;
                int from = Math.Max(1, current - 2);
                int to = Math.Min(total, current + 2);
            }

            @if (current > 1)
            {
                <a asp-action="Patients" asp-route-page="1" class="btn btn-sm mx-1 btn-outline-secondary">«</a>
                <a asp-action="Patients" asp-route-page="@(current - 1)" class="btn btn-sm mx-1 btn-outline-secondary">‹</a>
            }

            @for (int i = from; i <= to; i++)
            {
                <a asp-action="Patients" asp-route-page="@i"
                   class="btn btn-sm mx-1 @(i == current ? "btn-primary" : "btn-outline-secondary")">
                    @i
                </a>
            }

            @if (current < total)
            {
                <a asp-action="Patients" asp-route-page="@(current + 1)" class="btn btn-sm mx-1 btn-outline-secondary">›</a>
                <a asp-action="Patients" asp-route-page="@total" class="btn btn-sm mx-1 btn-outline-secondary">»</a>
            }
        </div>
    </div>
}