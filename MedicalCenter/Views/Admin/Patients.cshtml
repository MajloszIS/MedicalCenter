@model List<MedicalCenter.DTOs.PatientDto>

@{
    ViewData["Title"] = "Pacjenci";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-list me-2"></i>Pacjenci w Centrum Medycznym</h2>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-calendar-xmark text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak pacjentów</h4>
        <p class="text-muted">Nie masz jeszcze żadnych zarejestrowanych pacjentów.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Imię</th>
                    <th>Nazwisko</th>
                    <th>Telefon</th>
                    <th>PESEL</th>
                    <th class="text-center">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.FirstName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.LastName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.Phone</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.Pesel</div>
                        </td>
                        <td class="text-center">
                            <a asp-action="Index" asp-controller="MedicalRecord"
                               asp-route-patientId="@item.Id" class="btn btn-medical w-50 fw-bold">
                                <i class="fa-solid fa-circle-info me-2"></i> Karta Medyczna
                            </a>
                        </td>
                        <td class="text-center">
                            <form asp-action="DeletePatient" asp-controller="Admin" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="patientId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}