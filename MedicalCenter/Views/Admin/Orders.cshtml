@model List<MedicalCenter.DTOs.OrderDto>
@{
    ViewData["Title"] = "Wszystkie zamówienia";
}

<h2 class="page-title mb-4"><i class="fa-solid fa-boxes-stacked me-2"></i>Wszystkie zamówienia w systemie</h2>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID Zamówienia</th>
                <th>Pacjent</th>
                <th>Status</th>
                <th>Ocena</th>
                <th>Kwota</th>
                <th>Leki</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td><small class="text-muted">@order.Id.ToString().Substring(0, 8)...</small></td>
                    <td class="fw-bold">@order.PatientFullName</td>
                    <td><span class="badge bg-secondary">@order.StatusName</span></td>

                    <td>
                        @if (order.Rating.HasValue)
                        {
                            <div class="text-warning mb-1">
                                @for (int i = 0; i < order.Rating.Value; i++)
                                {
                                    <i class="fa-solid fa-star"></i>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(order.RatingComment))
                            {
                                <small class="text-muted d-block" style="max-width: 150px; font-style: italic;">"@order.RatingComment"</small>
                            }
                        }
                        else
                        {
                            <span class="text-muted small">Brak</span>
                        }
                    </td>

                    <td class="fw-bold text-success">@order.TotalPrice.ToString("C")</td>
                    <td>
                        @foreach (var item in order.Items)
                        {
                            <div>- @item.MedicineName (x@(item.Quantity))</div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="d-flex justify-content-center mt-3">
        @{
            int current = ViewBag.CurrentPage;
            int total = ViewBag.TotalPages;
            int from = Math.Max(1, current - 2);
            int to = Math.Min(total, current + 2);
        }

        @if (current > 1)
        {
            <a asp-action="Orders" asp-route-page="1" class="btn btn-sm mx-1 btn-outline-secondary">«</a>
            <a asp-action="Orders" asp-route-page="@(current - 1)" class="btn btn-sm mx-1 btn-outline-secondary">‹</a>
        }

        @for (int i = from; i <= to; i++)
        {
            <a asp-action="Orders" asp-route-page="@i"
               class="btn btn-sm mx-1 @(i == current ? "btn-primary" : "btn-outline-secondary")">
                @i
            </a>
        }

        @if (current < total)
        {
            <a asp-action="Orders" asp-route-page="@(current + 1)" class="btn btn-sm mx-1 btn-outline-secondary">›</a>
            <a asp-action="Orders" asp-route-page="@total" class="btn btn-sm mx-1 btn-outline-secondary">»</a>
        }
    </div>
</div>