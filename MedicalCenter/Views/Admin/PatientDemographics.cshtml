@model List<MedicalCenter.DTOs.PatientDemographicsDto>

@{
    ViewData["Title"] = "Demografia pacjentów";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">
        <i class="fa-solid fa-users me-2"></i>Demografia pacjentów
    </h2>
    <a asp-action="Analytics" asp-controller="Admin" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Wróć
    </a>
</div>

<div class="medical-card p-4 mb-4">
    <form method="get" asp-action="PatientDemographics" asp-controller="Admin">
        <div class="row align-items-end">
            <div class="col-md-4">
                <label class="form-label">Wiek od</label>
                <input type="number" name="ageFrom" value="@ViewBag.AgeFrom" class="form-control" min="0" max="120" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Wiek do</label>
                <input type="number" name="ageTo" value="@ViewBag.AgeTo" class="form-control" min="0" max="120" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fa-solid fa-search me-1"></i>Filtruj
                </button>
            </div>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-users text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak danych</h4>
        <p class="text-muted">Brak pacjentów w podanym przedziale wiekowym.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Grupa wiekowa</th>
                    <th>Płeć</th>
                    <th>Miasto</th>
                    <th class="text-center">Liczba pacjentów</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.AgeGroup</td>
                        <td>@item.Gender</td>
                        <td>@item.City</td>
                        <td class="text-center">
                            <span class="badge bg-primary">@item.PatientCount</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}