@model List<MedicalCenter.DTOs.DeliveryDto>

@{
    ViewData["Title"] = "Paczki kuriera";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">
        <i class="fa-solid fa-box me-2"></i>Paczki kuriera: <span class="text-primary">@ViewBag.CourierName</span>
    </h2>
    <a asp-controller="Admin" asp-action="Couriers" class="btn btn-outline-secondary fw-bold">
        <i class="fa-solid fa-arrow-left me-2"></i>Powrót do listy
    </a>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5 shadow-sm rounded border">
        <i class="fa-solid fa-box-open text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak przypisanych paczek</h4>
        <p class="text-muted">Ten kurier nie ma obecnie żadnych paczek do doręczenia.</p>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded border">
        <table class="table table-custom align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID Dostawy</th>
                    <th>Pacjent</th>
                    <th>Adres dostawy</th>
                    <th>Kwota zamówienia</th>
                    <th class="text-center">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="text-muted small">@item.Id.ToString().Substring(0, 8)...</span>
                        </td>
                        <td>
                            <div class="fw-bold">@item.PatientFullName</div>
                        </td>
                        <td>
                            <div>@item.DeliveryAddress</div>
                            <small class="text-muted">@item.PostalCode @item.City</small>
                        </td>
                        <td>
                            <div class="fw-bold text-success">@item.TotalPrice.ToString("C")</div>
                        </td>
                        <td class="text-center">
                            @if (item.StatusName == "W drodze")
                            {
                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-truck-fast me-1"></i> @item.StatusName</span>
                            }
                            else if (item.StatusName == "Dostarczono" || item.StatusName == "Zakończone")
                            {
                                <span class="badge bg-success"><i class="fa-solid fa-check-double me-1"></i> @item.StatusName</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.StatusName</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}