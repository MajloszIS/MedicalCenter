@model List<MedicalCenter.DTOs.AppointmentDto>

@{
    ViewData["Title"] = $"Wizyty Pacjenta {ViewBag.PatientName}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-user-md me-2"></i>Wizyty Pacjenta @ViewBag.PatientName</h2>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-calendar-xmark text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak zaplanowanych wizyt</h4>
        <p class="text-muted">Ten Pacjent nie ma jeszcze żadnych umówionych wizyt w naszym centrum.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Lekarz</th>
                    <th>Telefon</th>
                    <th>Data i Godzina</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Doctor.FirstName @item.Doctor.LastName</div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark">@item.Doctor.Phone</span>
                        </td>
                        <td>
                            <div class="text-primary fw-semibold">
                                <i class="fa-regular fa-clock me-1"></i> @item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </td>
                        <td>
                            @{
                                var statusClass = item.StatusName == "Zakończona" ? "bg-success" :
                                item.StatusName == "Odwołana" ? "bg-danger" : "bg-warning text-dark";
                            }
                            <span class="badge @statusClass">@item.StatusName</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}