@model MedicalCenter.DTOs.MedicineCreateDto

@{
    ViewData["Title"] = "Dodaj nowy lek";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-pills me-2"></i>Dodaj nowy lek</h2>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-md-8">

        <form asp-action="CreateMedicine" asp-controller="Admin" method="post" class="medical-card p-4">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-12 mb-4">
                    <h5 class="text-primary border-bottom pb-2">
                        <i class="fa-solid fa-circle-info me-2"></i>Informacje o leku
                    </h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Nazwa leku</label>
                            <input asp-for="Name" class="form-control" placeholder="np. Paracetamol" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Kategoria</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required>
                                <option value="">-- Wybierz kategorię --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="col-md-12 mb-2">
                    <h5 class="text-primary border-bottom pb-2">
                        <i class="fa-solid fa-boxes-stacked me-2"></i>Cennik i stan magazynowy
                    </h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Cena jednostkowa (PLN)</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="0.00" required />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Ilość w magazynie</label>
                            <input asp-for="StockQuantity" class="form-control" type="number" placeholder="0" required />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Opis / Dawkowanie (opcjonalnie)</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Szczegółowe informacje o leku..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 text-center">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>@ViewBag.Error
                </div>
            }

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-medical btn-lg fw-bold">Dodaj lek do bazy</button>
                <a asp-controller="Admin" asp-action="Index" class="btn btn-link text-muted">Anuluj i wróć</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}