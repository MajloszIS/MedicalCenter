@model MedicalCenter.DTOs.UpdateMedicineDto

@{
    ViewData["Title"] = $"Edytuj lek {Model.Name}";
}

<div class="container py-5">
    <h2 class="page-title">Lek: @Model.Name</h2>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="medical-card text-center">
                <div class="mb-3">
                    <i class="fa-solid fa-boxes-stacked text-primary" style="font-size: 100px;"></i>
                    <h4 class="mt-3">Stan: @Model.StockQuantity szt.</h4>
                    <h5 class="text-muted">Aktualna cena: @Model.Price.ToString("C")</h5>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="medical-card">
                <form asp-action="EditMedicine" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="medicineId" value="@ViewBag.MedicineId" />

                    <div class="d-flex align-items-center mb-3 bg-light p-2 rounded border border-success">
                        <label class="fw-semibold me-2 text-success" style="width: 140px;">Magazyn (szt.)</label>
                        <span id="stock-text" class="fw-bold fs-5">@Model.StockQuantity</span>
                        <input id="stock-input" name="StockQuantity" type="number" value="@Model.StockQuantity"
                               class="form-control form-control-sm ms-2" style="display:none; width:150px;" required />

                        <button type="button" id="stock-edit" onclick="enableEdit('stock')" class="btn btn-sm btn-link ms-2">
                            <i class="fa-solid fa-pen text-success"></i> Zmień stan
                        </button>
                        <button type="submit" id="stock-save" class="btn btn-sm btn-success ms-2" style="display:none;">
                            <i class="fa-solid fa-check"></i> Zapisz
                        </button>
                    </div>

                    <hr />

                    <div class="d-flex align-items-center mb-3">
                        <label class="fw-semibold me-2" style="width: 140px;">Cena (PLN)</label>
                        <span id="price-text">@Model.Price.ToString("0.00")</span>

                        <input id="price-input" name="Price" type="text"
                               value="@Model.Price.ToString("0.00")"
                               class="form-control form-control-sm ms-2" style="display:none; width:200px;" required />

                        <button type="button" id="price-edit" onclick="enableEdit('price')" class="btn btn-sm btn-link ms-2">
                            <i class="fa-solid fa-pen text-primary"></i>
                        </button>
                        <button type="submit" id="price-save" class="btn btn-sm btn-success ms-2" style="display:none;">
                            <i class="fa-solid fa-check"></i>
                        </button>
                    </div>

                    <div class="d-flex align-items-center mb-3">
                        <label class="fw-semibold me-2" style="width: 140px;">Nazwa leku</label>
                        <span id="name-text">@Model.Name</span>
                        <input id="name-input" name="Name" value="@Model.Name"
                               class="form-control form-control-sm ms-2" style="display:none; width:200px;" required />

                        <button type="button" id="name-edit" onclick="enableEdit('name')" class="btn btn-sm btn-link ms-2">
                            <i class="fa-solid fa-pen text-primary"></i>
                        </button>
                        <button type="submit" id="name-save" class="btn btn-sm btn-success ms-2" style="display:none;">
                            <i class="fa-solid fa-check"></i>
                        </button>
                    </div>

                    <div class="d-flex align-items-center mb-3">
                        <label class="fw-semibold me-2" style="width: 140px;">Kategoria</label>

                        <span id="category-text">@Model.CategoryName</span>

                        <select id="category-input" name="CategoryId" class="form-select form-select-sm ms-2" style="display:none; width:200px;" required>
                            @foreach (var category in ViewBag.Categories)
                            {
                                if (category.Id == Model.CategoryId)
                                {
                                    <option value="@category.Id" selected>@category.Name</option>
                                }
                                else
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            }
                        </select>

                        <button type="button" id="category-edit" onclick="enableEdit('category')" class="btn btn-sm btn-link ms-2">
                            <i class="fa-solid fa-pen text-primary"></i>
                        </button>
                        <button type="submit" id="category-save" class="btn btn-sm btn-success ms-2" style="display:none;">
                            <i class="fa-solid fa-check"></i>
                        </button>
                    </div>

                    <input type="hidden" name="Description" value="@Model.Description" />
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function enableEdit(fieldId) {
            const span = document.getElementById(`${fieldId}-text`);
            const input = document.getElementById(`${fieldId}-input`);
            const editBtn = document.getElementById(`${fieldId}-edit`);
            const saveBtn = document.getElementById(`${fieldId}-save`);

            span.style.display = 'none';
            input.style.display = 'inline';
            editBtn.style.display = 'none';
            saveBtn.style.display = 'inline';

            if (fieldId === 'price') {
                input.addEventListener('input', function() {
                    this.value = this.value.replace('.', ',');
                });
            }
        }
    </script>
}