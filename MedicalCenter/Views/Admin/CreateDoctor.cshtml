@model List<MedicalCenter.DTOs.SpecializationDto>

@{
    ViewData["Title"] = "Rejestracja Lekarza";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-user-md me-2"></i>Rejestracja Lekarza</h2>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-md-8">

        <form asp-action="CreateDoctor" asp-controller="Admin" method="post" class="medical-card p-4">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-12 mb-4">
                    <h5 class="text-primary border-bottom pb-2"><i class="fa-solid fa-lock me-2"></i>Dane konta</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Adres Email</label>
                            <input type="email" name="Email" class="form-control" placeholder="przyklad@poczta.pl" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Hasło</label>
                            <input type="password" name="Password" class="form-control" placeholder="Minimum 6 znaków" required />
                        </div>
                    </div>
                </div>

                <div class="col-md-12 mb-2">
                    <h5 class="text-primary border-bottom pb-2"><i class="fa-solid fa-address-card me-2"></i>Informacje osobowe</h5>
                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Imię</label>
                            <input type="text" name="FirstName" class="form-control" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Nazwisko</label>
                            <input type="text" name="LastName" class="form-control" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Numer telefonu</label>
                            <input type="tel" name="Phone" class="form-control" placeholder="np. 123456789" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Numer Licencji</label>
                            <input type="text" name="LicenseNumber" class="form-control" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Specjalizacja</label>

                            <select id="specialization-input" name="SpecializationName"
                                    class="form-select form-select-sm ms-2">
                                @foreach (var spec in Model)
                                {
                                    <option value="@spec.Name">
                                        @spec.Name
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Departamenty</label>
                            <div class="d-flex flex-wrap gap-2">
                                @if(ViewBag.Departments != null)
                                {
                                    @foreach (var dept in ViewBag.Departments)
                                    {
                                        <div class="form-check d-flex just">
                                            <input type="checkbox" id="dept-@dept.Id" name="SelectedDepartmentIds" value="@dept.Id" class="form-check-input" />
                                            <label for="dept-@dept.Id" class="form-check-label">@dept.Name</label>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="medical-card text-center py-5">
                                        <i class="fa-solid fa-home text-muted mb-3"></i>
                                        <p class="text-muted">Brak Departamentów </p>
                                        <span class="text-muted fst-italic" style="font-weight: normal; font-size: 0.85em;">
                                            dodaj nowe <a asp-action="Index" asp-controller="Department">Departamenty</a>
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 text-center">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>@ViewBag.Error
                </div>
            }

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-medical btn-lg fw-bold">Stwórz konto Lekarza</button>
                <a href="/Home" class="btn btn-link text-muted">Anuluj i wróć</a>
            </div>
        </form>
    </div>
</div>