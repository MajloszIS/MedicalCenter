@model List<MedicalCenter.DTOs.DoctorDto>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-user-md me-2"></i>Lekarze</h2>
    <a asp-controller="Admin" asp-action="Create" class="btn btn-outline-primary fw-bold">
		<i class="fa-solid fa-plus me-2"></i>Dodaj Lekarza
    </a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Imię</th>
            <th>Nazwisko</th>
            <th>Telefon</th>
            <th>Specjalizacja</th>
        </tr>
    </thead>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FirstName</td>
            <td>@item.LastName</td>
            <td>@item.Phone</td>
            <td>@item.SpecializationName</td>
            <td>
                <form asp-action="Delete" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DoctorId" value="@item.Id" />
                    <button type="submit">Usuń Lekarza</button>
                </form>
            </td>
        </tr>
    }
</table>