@model List<MedicalCenter.DTOs.DoctorDto>

@{
    ViewData["Title"] = "Lekarze";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0"><i class="fa-solid fa-user-md me-2"></i>Lekarze</h2>
    <a asp-controller="Admin" asp-action="Create" class="btn btn-outline-primary fw-bold">
		<i class="fa-solid fa-plus me-2"></i>Dodaj Lekarza
    </a>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-calendar-xmark text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak pacjentów</h4>
        <p class="text-muted">Nie masz jeszcze żadnych zarejestrowanych Lekarzy.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Imię</th>
                    <th>Nazwisko</th>
                    <th>Telefon</th>
                    <th>Specjalizacja</th>
                    <th class="text-center">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.FirstName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.LastName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.Phone</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.SpecializationName</div>
                        </td>
                        <td class="text-center">
                            <a asp-action="EditDoctor" asp-controller="Admin"
                                   asp-route-doctorId="@item.Id" class="fw-bold">
                                <i class="fa-solid fa-pen me-1"></i>
                            </a>
                        </td>
                        <td class="text-center">
                            <form asp-action="Delete" asp-controller="Admin" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="doctorId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}