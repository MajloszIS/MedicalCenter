@model List<MedicalCenter.Models.Doctor>

<h2>Lekarze</h2>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Imię</th>
            <th>Nazwisko</th>
            <th>Telefon</th>
            <th>Specjalizacja</th>
        </tr>
    </thead>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.User.FirstName</td>
            <td>@item.User.LastName</td>
            <td>@item.User.Phone</td>
            <td>@item.Specialization.Name</td>
            <td>
                <form asp-action="Create" asp-controller="Appointment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DoctorId" value="@item.Id" />
                    <button type="submit">Umów wizytę</button>
                </form>
            </td>
        </tr>
    }
</table>