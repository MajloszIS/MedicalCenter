@model List<MedicalCenter.DTOs.DeliveryDto>

@{
    ViewData["Title"] = "Panel Kuriera - Dostawy";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="page-title border-0 mb-0"><i class="fa-solid fa-truck-fast text-primary me-2"></i>Moje Trasy</h2>
        <p class="text-muted">Zarządzaj swoimi dostawami leków do pacjentów.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-box-open text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak przesyłek</h4>
        <p class="text-muted">Obecnie nie masz przypisanych żadnych dostaw do realizacji.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var delivery in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="medical-card h-100 d-flex flex-column border-top border-4 border-primary">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="fa-solid fa-clock me-1"></i> @delivery.StatusName</span>
                        <h5 class="text-success fw-bold mb-0">@delivery.TotalPrice.ToString("C")</h5>
                    </div>

                    <h5 class="fw-bold mb-1"><i class="fa-solid fa-user me-2 text-muted"></i>@delivery.PatientFullName</h5>
                    <p class="text-muted mb-3"><i class="fa-solid fa-location-dot me-2 text-danger"></i>@delivery.DeliveryAddress, @delivery.PostalCode @delivery.City</p>

                    <div class="mt-auto pt-3 border-top d-flex gap-2">
                        <form asp-action="ChangeStatus" method="post" class="w-50">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="deliveryId" value="@delivery.Id" />
                            <input type="hidden" name="statusName" value="W drodze" />
                            <button type="submit" class="btn btn-outline-primary w-100 fw-bold" @(delivery.StatusName == "W drodze" || delivery.StatusName == "Dostarczono" ? "disabled" : "")>
                                <i class="fa-solid fa-truck me-1"></i> W drogę
                            </button>
                        </form>

                        <form asp-action="ChangeStatus" method="post" class="w-50">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="deliveryId" value="@delivery.Id" />
                            <input type="hidden" name="statusName" value="Dostarczono" />
                            <button type="submit" class="btn btn-success w-100 fw-bold" @(delivery.StatusName == "Dostarczono" ? "disabled" : "")>
                                <i class="fa-solid fa-check me-1"></i> Dostarczono
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}