@model List<MedicalCenter.Models.Patient>

<a href="/Patients/Create">Dodaj pacjenta</a>

<h2>Patients</h2>

<table>
    <tr>
        <th>Id</th>
        <th>Pesel</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Pesel</td>
            <td><a href="/Patients/Delete/@item.Id">Usuń</a><td>
        </tr>
    }
</table>