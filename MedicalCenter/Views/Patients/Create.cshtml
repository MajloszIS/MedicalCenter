@model MedicalCenter.Models.Patient

<h2>Dodaj pacjenta</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <h4>Dane konta</h4>

    <div>
        <label>Imię</label>
        <input type="text" name="FirstName" required />
    </div>

    <div>
        <label>Nazwisko</label>
        <input type="text" name="LastName" required />
    </div>

    <div>
        <label>Email</label>
        <input type="email" name="Email" required />
    </div>

    <div>
        <label>Telefon</label>
        <input type="tel" name="Phone" />
    </div>

    <div>
        <label>Hasło</label>
        <input type="password" name="PasswordHash" required />
    </div>

    <h4>Dane pacjenta</h4>

    <div>
        <label>PESEL</label>
        <input asp-for="Pesel" />
        <span asp-validation-for="Pesel" class="text-danger"></span>
    </div>

    <div>
        <label>Data urodzenia</label>
        <input asp-for="BirthDate" type="date" />
    </div>

    <button type="submit">Dodaj pacjenta</button>
</form>

<a href="/Patients">Powrót</a>