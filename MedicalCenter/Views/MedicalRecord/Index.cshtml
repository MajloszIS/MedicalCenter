@model MedicalCenter.DTOs.MedicalRecordDto

<h2>Karta Medyczna</h2>

<div class="container py-3">
    <div class="row g-4">
        
        <!-- lewa kolumna -->
        <div class="col-lg-8">
            <!-- info o pacjencie -->
            <div class="medical-card mb-4">

				<h3>
					<i class="fa-solid fa-user me-2"></i>
					@Model.Patient.FirstName @Model.Patient.LastName
				</h3>

				<div class="row g-4">
					<div class="col-6">
						<div class="d-flex align-items-center mb-1">
							<i class="fa-solid fa-phone me-2 text-primary"></i>
							<p class="text-muted small mb-0">Telefon</p>
						</div>
						<p class="fw-semibold">@Model.Patient.Phone</p>
					</div>

					<div class="col-6">
						<div class="d-flex align-items-center mb-1">
							<i class="fa-solid fa-id-card me-2 text-primary"></i>
							<p class="text-muted small mb-0">Pesel</p>
						</div>
						<p class="fw-semibold">@Model.Patient.Pesel</p>
					</div>
				</div>
            </div>
            <!-- diagnozy -->
            <div>
				<div class="medical-card mb-4">
					<div>
						<h2 class="mb-3">Dodaj diagnozę</h2>
						<form asp-action="AddDiagnosis" asp-controller="MedicalRecord" method="post">
							@Html.AntiForgeryToken()

							<input type="hidden" name="medicalRecordId" value="@Model.Id" />
							<input type="hidden" name="patientId" value="@Model.PatientId" />

							<div class="mb-3">
								<textarea class="form-control" name="description" placeholder="Dodaj opis diagnozy" required></textarea>
							</div>

							<div>
								@if (ViewBag.Error != null)
								{
									<span>@ViewBag.Error</span>
								}
							</div>
							<button class="btn btn-medical" type="submit">Dodaj</button>
						</form>
					</div>
				</div>
				<div>
					<h2>Diagnozy</h2>

					@if (Model.Diagnoses != null && Model.Diagnoses.Any())
					{
						@foreach (var diagnosis in Model.Diagnoses)
						{
							<div class="medical-card">
								<div class="d-flex align-items-center mb-1">
									<i class="fa-solid fa-list-alt me-2 text-primary"></i>
									<p class="text-muted small mb-0">Opis</p>
								</div>
								<p>@diagnosis.Description</p>

								<h6 class="text-muted mt-3">
									<i class="fa-solid fa-pills me-1"></i>Dodaj leczenie
								</h6>
								<form asp-action="AddTreatment" asp-controller="MedicalRecord" method="post">
									@Html.AntiForgeryToken()

									<input type="hidden" name="diagnosisId" value="@diagnosis.Id" />
									<input type="hidden" name="patientId" value="@Model.PatientId" />

									<div class="mb-3 col-4">
										<textarea class="form-control form-control-sm" rows="2" name="description" placeholder="Dodaj opis leczenia" required></textarea>
									</div>

									<div>
										@if (ViewBag.Error != null)
										{
											<span>@ViewBag.Error</span>
										}
									</div>
									<button class="btn btn-outline-primary btn-sm" type="submit">
										<i class="fa-solid fa-plus me-1"></i>Dodaj leczenie
									</button>
								</form>


								<h6 class="text-muted mt-3">
									<i class="fa-solid fa-book-medical me-1"></i>Leczenie
								</h6>
								@foreach (var treatments in diagnosis.Treatments)
								{
									<p>@treatments.Description</p>
								}
							</div>
						}
					}
				</div>
            </div>
        </div>

        <!-- prawa kolumna -->
        <div class="col-lg-4">
            <!-- dodaj receptę -->
            <div class="medical-card mb-4">
				<div>

					<h1>Dodaj nową Receptę</h1>
					
					<form asp-action="AddPrescription" asp-controller="MedicalRecord" method="post">
						@Html.AntiForgeryToken()

						<input type="hidden" name="medicalRecordId" value="@Model.Id" />
						<input type="hidden" name="patientId" value="@Model.PatientId" />

						<div>
							<label class="">Wybierz lek:</label>
							<select id="medicineSelect" class="form-select d-flex gap-2 mb-3">
								@foreach (var medicine in ViewBag.Medicines)
								{
									<option value="@medicine.Id" data-name="@medicine.Name">@medicine.Name</option>
								}
							</select>

							<label class="">Ilość:</label>
							<input type="number" id="quantityInput" class="form-control mb-3" min="1" value="1" />

							<button class="btn btn-outline-primary btn-sm mb-3" type="button" onclick="addMedicine()">
								<i class="fa-solid fa-plus me-1"></i>Dodaj lek
							</button>
						</div>

		

						<div id="selected-medicines">
							<!-- tu będą wybrane leki -->
						</div>

						<div>
							@if (ViewBag.Error != null)
							{
								<span>@ViewBag.Error</span>
							}
						</div>

						<button class="btn btn-medical" type="submit">Dodaj</button>

					</form>

				</div>
            </div>
            <!-- lista recept -->
			<h1>Recepty</h1>
			@if (Model.Prescriptions != null && Model.Prescriptions.Any())
			{
				@foreach (var prescription in Model.Prescriptions)
				{
					<div class="medical-card">
					@if (prescription.Items != null && prescription.Items.Any())
					{
						<div class="d-flex align-items-center mb-3">
							<i class="fa-solid fa-file-medical text-primary me-2"></i>
							<h6 class="fw-bold mb-0">Recepta</h6>
						</div>
						<hr class="mt-0">
						@foreach (var item in prescription.Items)
						{
							<div class="d-flex align-items-center justify-content-between border rounded p-2 mb-2">
								<div>
									<i class="fa-solid fa-pills text-primary me-2"></i>
									<span class="fw-semibold">@item.Medicine.Name</span>
									<span class="text-muted ms-2">— @item.Quantity szt.</span>
								</div>
								<button type="button" class="btn btn-sm btn-outline-danger" onclick="removeItem('item-${itemCount}')">
									<i class="fa-solid fa-xmark"></i>
								</button>
								<input type="hidden" name="medicineIds" value="@item.MedicineId" />
								<input type="hidden" name="quantities" value="@item.Quantity" />
							</div>
						}
					}
					</div>
				}
			}
        </div>
    </div>
</div>


@section Scripts {
	<script>
		let itemCount = 0;

		function addMedicine() {
			const select = document.getElementById('medicineSelect');
			const quantity = document.getElementById('quantityInput').value;
			const medicineId = select.value;
			const medicineName = select.options[select.selectedIndex].dataset.name;

			if (!medicineId || quantity < 1) return;

			const container = document.getElementById('selected-medicines');
			const div = document.createElement('div');
			div.id = `item-${itemCount}`;
			div.innerHTML = `
				<div class="d-flex align-items-center justify-content-between border rounded p-2 mb-2">
					<div>
						<i class="fa-solid fa-pills text-primary me-2"></i>
						<span class="fw-semibold">${medicineName}</span>
						<span class="text-muted ms-2">— ${quantity} szt.</span>
					</div>
					<button type="button" class="btn btn-sm btn-outline-danger" onclick="removeItem('item-${itemCount}')">
						<i class="fa-solid fa-xmark"></i>
					</button>
					<input type="hidden" name="medicineIds" value="${medicineId}" />
					<input type="hidden" name="quantities" value="${quantity}" />
				</div>
			`;
			container.appendChild(div);
			itemCount++;
		}

		function removeItem(id) {
			document.getElementById(id).remove();
		}
	</script>
}
