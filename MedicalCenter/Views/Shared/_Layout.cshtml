<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedicalCenter</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MedicalCenter.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-4">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-notes-medical me-2"></i>MedicalCenter
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @if(User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item d-flex align-items-center">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Profile">
                                    <span class="navbar-text me-3 fw-semibold">Witaj, @User.Identity?.Name</span>
                                </a>
                            </li>
                        </ul>
                    }

                    <div class="d-flex align-items-center">
                        @if (User.IsInRole("Courier"))
                        {
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-courier"
                                           asp-controller="Courier"
                                           asp-action="Index">
                                        <i class="fa-solid fa-truck-fast me-2"></i>Panel Kuriera
                                    </a>
                                </li>
                            </ul>
                        }

                        @if (User.IsInRole("Doctor"))
                        {
                            <ul class="navbar-nav flex-row gap-2">
                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-doctor"
                                           asp-controller="Doctor"
                                           asp-action="Index">
                                        <i class="fa-solid fa-calendar-check me-1"></i>Wizyty
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-doctor"
                                           asp-controller="Doctor"
                                           asp-action="Patients">
                                        <i class="fa-solid fa-user-injured me-1"></i>Pacjenci
                                    </a>
                                </li>
                            </ul>
                        }

                        @if (User.IsInRole("Patient"))
                        {
                            <ul class="navbar-nav flex-row flex-wrap gap-2">
                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Doctors" asp-action="Index">
                                        <i class="fa-solid fa-user-doctor me-1"></i>Lekarze
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Appointment" asp-action="Index">
                                        <i class="fa-solid fa-calendar-days me-1"></i>Wizyty
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Diagnosis" asp-action="Index">
                                        <i class="fa-solid fa-notes-medical me-1"></i>Diagnozy
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Prescription" asp-action="Index">
                                        <i class="fa-solid fa-file-prescription me-1"></i>Recepty
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="MedicalLeave" asp-action="MedicalLeaves">
                                        <i class="fa-solid fa-bed me-1"></i>Zwolnienia
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Referral" asp-action="Referrals">
                                        <i class="fa-solid fa-share-from-square me-1"></i>Skierowania
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Medicines" asp-action="Index">
                                        <i class="fa-solid fa-capsules me-1"></i>Apteka
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Cart" asp-action="Index">
                                        <i class="fa-solid fa-cart-shopping me-1"></i>Koszyk
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-patient" asp-controller="Order" asp-action="MyOrders">
                                        <i class="fa-solid fa-box me-1"></i>Zamówienia
                                    </a>
                                </li>
                            </ul>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <ul class="navbar-nav flex-row flex-wrap gap-2">
                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Admin"
                                           asp-action="Index">
                                        <i class="fa-solid fa-list me-1"></i>Panel
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Admin"
                                           asp-action="Patients">
                                        <i class="fa-solid fa-users me-1"></i>Pacjenci
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Admin"
                                           asp-action="Doctors">
                                        <i class="fa-solid fa-user-doctor me-1"></i>Lekarze
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Admin"
                                           asp-action="Couriers">
                                        <i class="fa-solid fa-truck-fast me-1"></i>Kurierzy
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Specialization"
                                           asp-action="Specializations">
                                        <i class="fa-solid fa-stethoscope me-1"></i>Specjalizacje
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Admin"
                                           asp-action="Orders">
                                        <i class="fa-solid fa-box me-1"></i>Zamówienia
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Admin"
                                           asp-action="Medicines">
                                        <i class="fa-solid fa-capsules me-1"></i>Leki
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="Department"
                                           asp-action="Index">
                                        <i class="fa-solid fa-building me-1"></i>Departamenty
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                           asp-controller="MedicineCategories"
                                           asp-action="Index">
                                        <i class="fa-solid fa-tags me-1"></i>Kategorie leków
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link nav-pill nav-admin"
                                       asp-controller="Admin"
                                       asp-action="Analytics">
                                        <i class="fa-solid fa-chart-bar me-1"></i>Analizy
                                    </a>
                                </li>
                            </ul>
                        }
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item d-flex align-items-center">
                                <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm m-lg-3">Wyloguj</button>
                                </form>
                            </li>
                        </ul>
                    }

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fa-solid fa-circle-check me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-auto py-3">
        <div class="container text-center">
            &copy; 2026 - MedicalCenter - <a asp-area="" asp-controller="Home" asp-action="Privacy">Polityka prywatności</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @RenderSection("Styles", required: false)
</body>
</html>