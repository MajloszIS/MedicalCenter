@model List<MedicalCenter.DTOs.MedicalLeaveDto>

@{
    ViewData["Title"] = "Zwolnienia";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h2 class="page-title mb-0"><i class="fa-solid fa-bed-pulse me-2"></i>Twoje Zwolnienia</h2>
</div>

@if (!Model.Any())
{
    <div class="medical-card text-center py-5">
        <i class="fa-solid fa-bed-pulse text-muted mb-3" style="font-size: 3rem;"></i>
        <h4>Brak Zwolnień</h4>
        <p class="text-muted">Nie masz jeszcze żadnych zwolnień.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Lekarz</th>
                    <th>Od</th>
                    <th>Do</th>
                    <th>Powód</th>
                    <th class="text-center">Akcje</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.DoctorFulLName</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.DateFrom.ToString("dd-MM-yyyy")</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.DateTo.ToString("dd-MM-yyyy")</div>
                        </td>
                        <td>
                            <div class="">@item.Reason</div>
                        </td>
                        <td class="text-center">
                            <a asp-action="DownloadPdf" asp-controller="MedicalLeave" asp-route-id="@item.Id" class="btn btn-primary">
                                Pobierz Zwolnienie
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}